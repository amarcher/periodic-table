# ElevenLabs Conversational AI Agent ID
# Create an agent at https://elevenlabs.io → Conversational AI → Create Agent
# Then paste the Agent ID here
VITE_ELEVENLABS_AGENT_ID=

# ---------------------------------------------------------------------------
# Cloudflare R2 — used by scripts/r2-upload/upload.ts
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ---------------------------------------------------------------------------

# Found in the Cloudflare dashboard under R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id

# From your R2 API token (read/write access required)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# The name of your R2 bucket
R2_BUCKET_NAME=periodic-table-videos

# Public base URL for the bucket — either a custom domain you've connected
# to R2, or the default r2.dev URL (enable "Allow Access" in the R2 bucket
# settings to use the *.r2.dev subdomain).
# Example: https://pub-abc123def456.r2.dev
R2_PUBLIC_URL=https://pub-replace-with-your-token.r2.dev

# Vite / frontend — set this to the same value as R2_PUBLIC_URL in production.
# In dev this is intentionally left unset so videos are served from public/.
# In Vercel: add VITE_VIDEO_CDN_URL as an environment variable in project settings.
# VITE_VIDEO_CDN_URL=https://pub-replace-with-your-token.r2.dev
